import random, time

class SmoothieMakersGame:
    def __init__(self):
        self.money = 0
        self.smoothies_blended = 0
        self.blender_limit = 5
        self.cashier_boost = 1
        self.backpack_limit = 10
        self.items_in_backpack = 0
        self.item1_count = 0
        self.item2_count = 0
        self.item3_count = 0
        self.ingredients = {"Banana":0 ,"Strawberry":0,"Milk":0,"Blueberry":0,"Apple":0,"Pear":0}

    def get_user_choice(self, prompt_message, options_dict):
        while True:
            print(prompt_message)
            for key, value in options_dict.items():
                print(f"{key}. {value}")
            choice = input("Enter your choice: ")
            if choice in options_dict:
                return choice
            else:
                print("Invalid choice!")

    def starting_menu(self):
        print("Welcome to...")
        time.sleep(0.5)
        print("Smoothie Makers!")
        menu_options = {
            "1": "Make a smoothie",
            "2": "Collect ingredients",
            "3": "Show money",
            "4": "Shop",
            "5": "Leave"
        }
        while True:
            choice = self.get_user_choice("\nWhat would you like to do?", menu_options)
            if choice == "1":
                self.make_smoothie()
            elif choice == "2":
                self.collect_ingredients()
            elif choice == "3":
                self.show_money()
            elif choice == "4":
                self.shop()
            elif choice == "5":
                print("Thanks for playing!")
                print("Game created by Ethan Tan and Pan Chenxuan")
                return

    def show_money(self):
        print(f"You have ${self.money}.")

    def display_smoothies_blended_count(self):
        print(f"You have blended {self.smoothies_blended} smoothies.")

    def deduct_ingredients(self, ingredient_type, quantity, smoothie_ingredients):
        if self.ingredients[ingredient_type] >= quantity:
            self.ingredients[ingredient_type] -= quantity
            smoothie_ingredients.extend([ingredient_type] * quantity)
            print(f"Used {quantity} of {ingredient_type}.")
            self.items_in_backpack -= quantity
        else:
            print(f"Insufficient {ingredient_type}! You only have {self.ingredients[ingredient_type]}.")

    def collect_ingredients(self):
        area_options = {
            "1": "Basic Area",
            "2": "Advanced Area",
            "3": "Go back to main menu"
        }
        while True:
            area_choice = self.get_user_choice("\nWhere would you like to collect ingredients?", area_options)
            if area_choice == "1":
                print("Heading to the basic area...\n")
                time.sleep(3)
                self.basic_area()
            elif area_choice == "2":
                print("Heading to the advanced area...\n")
                time.sleep(5)
                self.advanced_area()
            elif area_choice == "3":
                return

    def basic_area(self):
        print("Welcome to the basic area!")
        print("You can collect milk, banana, and strawberry here.")
        area_options = {
            "1": "Scavenge for ingredients.",
            "2": "Go back to ingredient collection menu."
        }
        while True:
            scavenge_choice = self.get_user_choice("\nWhat would you like to do?", area_options)
            if scavenge_choice == "1":
                if self.items_in_backpack == self.backpack_limit:
                    print("Backpack limit reached!")
                    continue
                else:
                    print("Scavenging for ingredients...")
                    time.sleep(random.randint(2, 6))
                    found_ingredient = random.choice(["Milk", "Banana", "Strawberry"])
                    print(f"You found {found_ingredient}!")
                    self.ingredients[found_ingredient] += 1
                    self.items_in_backpack += 1
            elif scavenge_choice == "2":
                return

    def advanced_area(self):
        if self.smoothies_blended < 5:
            print("You need to blend at least 5 smoothies before accessing the advanced area!")
            return
        else:
            print("Welcome to the advanced area!")
            print("You can collect pear, apple, and blueberry here.")
            area_options = {
                "1": "Scavenge for ingredients.",
                "2": "Go back to ingredient collection menu."
            }
            while True:
                scavenge_choice = self.get_user_choice("\nWhat would you like to do?", area_options)
                if scavenge_choice == "1":
                    if self.items_in_backpack == self.backpack_limit:
                        print("Backpack limit reached!")
                        continue
                    else:
                        print("Scavenging for ingredients...")
                        time.sleep(random.randint(2, 6))
                        found_ingredient = random.choice(["Blueberry", "Apple", "Pear"])
                        print(f"You found {found_ingredient}!")
                        self.ingredients[found_ingredient] += 1
                        self.items_in_backpack += 1
                elif scavenge_choice == "2":
                    return

    def make_smoothie(self):
        smoothie_ingredients = []
        ingredient_mapping = {
            "1": "Banana", "2": "Strawberry", "3": "Milk",
            "4": "Blueberry", "5": "Apple", "6": "Pear"
        }
        smoothie_prices_mapping={
            "Banana": 3.5, "Milk":3, "Strawberry":4.5,
            "Pear":7, "Apple":8, "Blueberry":10
        }
        while True:
            print("\nAdd ingredients to your smoothie:")
            print("You have:")
            for item, count in self.ingredients.items():
                print(f"{item}: {count}")

            ingredient_choices = {k: v for k, v in ingredient_mapping.items()}
            ingredient_choices["7"] = "Finish making smoothie"

            choice = self.get_user_choice("\nWhich ingredient would you like to add?", ingredient_choices)

            if choice == "7":
                if len(smoothie_ingredients) >= 1:
                    print(f"Your smoothie contains: {', '.join(smoothie_ingredients)}")
                    print("Mixing...")
                    time.sleep(3)
                    smoothie_price = sum(smoothie_prices_mapping[i] for i in smoothie_ingredients) * self.cashier_boost
                    self.money += smoothie_price
                    self.smoothies_blended += 1
                    print(f"Congrats! You sold your smoothie for ${smoothie_price}!")
                    self.show_money()
                    self.display_smoothies_blended_count()
                else:
                    print("You do not have any ingredients added to your smoothie")
                break
            else:
                selected_ingredient = ingredient_mapping[choice]
                try:
                    quantity = int(input(f"How many {selected_ingredient} would you like to add? "))
                    if quantity <= 0:
                        print("Quantity must be positive.")
                        continue
                    if (len(smoothie_ingredients) + quantity) > self.blender_limit:
                        print(f"Adding {quantity} {selected_ingredient} would exceed the {self.blender_limit}-ingredient limit. You can only add {self.blender_limit - len(smoothie_ingredients)} more.")
                        continue
                    self.deduct_ingredients(selected_ingredient, quantity, smoothie_ingredients)
                except ValueError:
                    print("Invalid quantity. Please enter a number.")

    def shop(self):
        print("\nWelcome to the shop!")
        print("Here, you can buy upgrades for your blender and better cashiers!")
        time.sleep(0.5)

        while True:
            item1_cost = 100 + 150 * self.item1_count
            item2_cost = 300 + 450 * self.item2_count
            item3_cost = 100 + 50 * self.item3_count

            shop_options = {
                "1": f"Upgrade blender (Cost: ${item1_cost})",
                "2": f"Upgrade cashiers (Cost: ${item2_cost})",
                "3": f"Upgrade Backpack size (Cost: ${item3_cost})",
                "4": "Go back to main menu"
            }
            self.show_money()
            choice = self.get_user_choice("\nWhat would you like to buy?", shop_options)

            if choice == "1":
                if self.money >= item1_cost:
                    self.money -= item1_cost
                    self.blender_limit += 5
                    self.item1_count += 1
                    print("Blender upgraded! You can now add more ingredients to your smoothie!")
                    self.show_money()
                else:
                    print("You don't have enough money to buy this item.")
            elif choice == "2":
                if self.money >= item2_cost:
                    self.money -= item2_cost
                    self.item2_count += 1
                    self.cashier_boost += 0.2
                    self.cashier_upgraded = True
                    print("Cashiers upgraded! You can now sell smoothies at a higher price!")
                    self.show_money()
                else:
                    print("You don't have enough money to buy this item.")
            elif choice == "3":
                if self.money >= item3_cost:
                    self.money -= item3_cost
                    self.item3_count += 1
                    self.backpack_limit += 10
                    print("Backpack upgraded! You can now carry more ingredients!")
                    self.show_money()
                else:
                    print("You don't have enough money to buy this item.")
            elif choice == "4":
                print("Exiting shop...")
                time.sleep(2)
                return

game = SmoothieMakersGame()
game.starting_menu()
